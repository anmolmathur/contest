# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local DB dumps
/backups
*.dump

# local agent config
/.claude

# Production sync — never commit raw prod data
scripts/sync-from-prod/*.sql
!scripts/sync-from-prod/anonymize.sql
!scripts/sync-from-prod/post-process.sql
scripts/sync-from-prod/inbox/*
!scripts/sync-from-prod/inbox/README.md
scripts/sync-from-prod/backups/
